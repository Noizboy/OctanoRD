{
  "permissions": {
    "defaultMode": "acceptEdits"
  },
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"]
    },
    "semgrep": {
      "command": "npx",
      "args": ["-y", "semgrep-mcp"]
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"]
    }
  }
}
